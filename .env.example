# URL ou IP onde o Ollama está rodando
OLLAMA_HOST=http://localhost:11434

# Qual modelo do Ollama rodar (ex: gemma2, gemma:7b)
OLLAMA_MODEL=gemma2

# Token clássico do Github (Personal Access Token). Escopo de Repo é necessário.
GITHUB_TOKEN=ghp_suachaveaqui

# Repositório alvo, formato: "owner/repo" (ex: "juninmd/jules-orchestrator")
TARGET_REPO=juninmd/jules-orchestrator

# Configuração da API do Jules para iniciar a sessão
JULES_API_URL=http://localhost:3000/api/jules/invoke
JULES_API_KEY=sua_chave_do_jules

